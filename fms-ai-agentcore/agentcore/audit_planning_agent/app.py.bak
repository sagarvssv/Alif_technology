import json
import os
import traceback
from concurrent.futures import ThreadPoolExecutor, as_completed
from http.server import BaseHTTPRequestHandler, HTTPServer

AGENT_NAME = "audit_planning_agent"
PORT = int(os.environ.get("PORT", "8080"))

# Max time (seconds) we'll wait for ALL section generations to complete.
# Keep this comfortably under any upstream gateway/runtime timeout.
SECTION_GENERATION_TIMEOUT = int(os.environ.get("SECTION_GENERATION_TIMEOUT", "90"))


def safe_json_dumps(data):
    return json.dumps(data, ensure_ascii=False)


def safe_json_loads(value, default=None):
    if default is None:
        default = {}

    if not value:
        return default

    if isinstance(value, bytes):
        value = value.decode("utf-8", errors="ignore")

    try:
        return json.loads(value)
    except Exception:
        return default


def prepare_imports():
    import sys

    current_dir = os.path.dirname(os.path.abspath(__file__))
    agentcore_dir = os.path.abspath(os.path.join(current_dir, ".."))

    if agentcore_dir not in sys.path:
        sys.path.append(agentcore_dir)


def run_agent(payload):
    prepare_imports()

    from shared.bedrock import invoke_claude
    from shared.kb import retrieve_from_kb, format_citations
    from shared.report_context import get_report_context, build_context_summary
    from shared.utils import (
        build_response,
        compact_text,
        get_direct_context_from_payload,
        get_message_from_payload,
        get_report_id_from_payload,
    )

    original_user_message = get_message_from_payload(payload)
    report_id = get_report_id_from_payload(payload)
    direct_context = get_direct_context_from_payload(payload)

    user_message = original_user_message or "Generate audit planning."

    report_context = get_report_context(
        report_id=report_id,
        direct_context=direct_context,
    )

    kb_query = build_kb_query(user_message, report_context, compact_text)
    kb_context, citations = retrieve_from_kb(kb_query, number_of_results=6)

    context_summary = build_context_summary(compact_text(report_context, max_chars=18000))
    citation_details = format_citations(citations)

    answer = generate_complete_audit_planning_output(
        invoke_claude=invoke_claude,
        user_message=user_message,
        report_context=context_summary,
        kb_context=kb_context,
        citation_details=citation_details,
    )

    return build_response(
        answer=answer,
        selected_agent=AGENT_NAME,
        citations=citations,
        extra={
            "agentType": "sub_agent",
            "agentName": "Audit Planning Agent",
        },
    )


def build_kb_query(user_message, report_context, compact_text):
    query = user_message

    if report_context:
        query += "\n\nUploaded document context summary:\n"
        query += compact_text(report_context, max_chars=3000)

    query += """

Find authoritative audit planning guidance related to:
- engagement strategy
- planning memorandum
- materiality calculation
- risk assessment
- audit programs
- staffing recommendations
- IFRS
- ISA
- ISQM
- audit compliance
"""

    return query


def base_system_prompt():
    return """
You are the Audit Planning Agent for FMS AI AgentCore.

Use the uploaded financial statement/report context.
Do not repeat the raw extracted document.
Do not generate the old 22-section BRD assessment report.
Use professional audit language.
Use uploaded document facts exactly.
Do not invent financial values.
If information is missing, write: Not available in provided document/context.
Keep the section concise and complete.
Use citations like [S1], [S2] only when supported by Knowledge Base context.
"""


def section_prompt(section_name, instructions, user_message, report_context, kb_context, citation_details):
    return f"""
User request:
{user_message}

Uploaded financial statement/report context:
{report_context}

Knowledge Base context:
{kb_context or "No Knowledge Base context retrieved."}

Citation details:
{citation_details}

Generate ONLY this section:

# {section_name}

Instructions:
{instructions}

Do not generate any other section.
Do not include a conclusion.
"""


def generate_section(
    invoke_claude,
    section_name,
    instructions,
    user_message,
    report_context,
    kb_context,
    citation_details,
    max_tokens=2500,
):
    """
    Generates a single section. On failure, returns a clearly labeled
    fallback block instead of raising, so one bad section doesn't
    take down the whole report.
    """
    try:
        result = invoke_claude(
            system_prompt=base_system_prompt(),
            user_prompt=section_prompt(
                section_name=section_name,
                instructions=instructions,
                user_message=user_message,
                report_context=report_context,
                kb_context=kb_context,
                citation_details=citation_details,
            ),
            max_tokens=max_tokens,
            temperature=0.15,
        )
        return (result or "").strip()
    except Exception as exc:
        return (
            f"# {section_name}\n\n"
            f"_This section could not be generated due to an internal error: {str(exc)}_"
        )


# Section definitions: (key, section_name, instructions, max_tokens)
SECTION_DEFINITIONS = [
    (
        "engagement_strategy",
        "Engagement Strategy",
        """
Include concise bullets for:
- client background
- financial statement context
- engagement scope
- applicable reporting/audit considerations
- key audit focus areas
- planned audit approach

Maximum 8 bullets or table rows.
""",
        2500,
    ),
    (
        "planning_memorandum",
        "Planning Memorandum",
        """
Include concise bullets or a compact table for:
- audit objective
- scope
- reporting framework
- significant account areas
- audit approach
- timeline
- management responsibilities
- audit team responsibilities

Maximum 8 bullets or table rows.
""",
        2500,
    ),
    (
        "materiality",
        "Materiality Calculation",
        """
Use uploaded financial data where available.
Show benchmark calculations for:
- profit before tax
- revenue
- total assets

Include:
- recommended overall materiality
- performance materiality
- clearly trivial threshold
- rationale for selected benchmark

Use source values exactly.
Do not leave incomplete table cells.
Do not stop in the middle of a table.
""",
        3000,
    ),
    (
        "risk_assessment",
        "Risk Assessment",
        """
Include this table:

| Risk Area | Source Fact | Risk Description | Risk Level | Planned Audit Response |
| --- | --- | --- | --- | --- |

Cover where relevant:
- inventory valuation
- revenue cutoff
- receivables recoverability
- related parties
- VAT/corporate tax
- going concern
- management override/fraud risk

Maximum 8 rows.
""",
        3500,
    ),
    (
        "audit_programs",
        "Audit Programs",
        """
Create concise practical audit procedures for:
- inventory
- revenue
- trade receivables
- related parties
- tax/VAT
- going concern
- financial statement close and disclosures

Use bullet points grouped by audit area.
Maximum 8 audit areas.
""",
        3500,
    ),
    (
        "staffing",
        "Staffing Recommendations",
        """
Recommend concise staffing for:
- engagement partner
- audit manager
- senior auditor
- assistant auditor
- tax/compliance specialist
- review intensity
- estimated effort by risk area

Maximum 8 bullets or table rows.
""",
        2500,
    ),
]


def generate_complete_audit_planning_output(
    invoke_claude,
    user_message,
    report_context,
    kb_context,
    citation_details,
):
    """
    Generates all sections in PARALLEL using a thread pool, since each
    section is an independent Bedrock call. This significantly reduces
    total wall-clock time compared to calling them one after another,
    which is the most likely cause of "Failed to fetch" / timeout errors
    on the frontend.
    """
    results = {}

    with ThreadPoolExecutor(max_workers=len(SECTION_DEFINITIONS)) as executor:
        future_to_key = {
            executor.submit(
                generate_section,
                invoke_claude,
                section_name,
                instructions,
                user_message,
                report_context,
                kb_context,
                citation_details,
                max_tokens,
            ): key
            for key, section_name, instructions, max_tokens in SECTION_DEFINITIONS
        }

        try:
            for future in as_completed(future_to_key, timeout=SECTION_GENERATION_TIMEOUT):
                key = future_to_key[future]
                try:
                    results[key] = future.result()
                except Exception as exc:
                    results[key] = f"# {key}\n\n_Section failed: {str(exc)}_"
        except TimeoutError:
            # Some futures didn't finish in time. Fill in whatever
            # completed, and mark the rest as timed out instead of
            # hanging the whole request indefinitely.
            for future, key in future_to_key.items():
                if key not in results:
                    if future.done():
                        try:
                            results[key] = future.result()
                        except Exception as exc:
                            results[key] = f"# {key}\n\n_Section failed: {str(exc)}_"
                    else:
                        results[key] = f"# {key}\n\n_Section generation timed out._"

    ordered_keys = [key for key, _, _, _ in SECTION_DEFINITIONS]

    return "\n\n---\n\n".join(
        ["# Audit Planning Deliverables"] + [results[key] for key in ordered_keys]
    )


class AgentCoreHTTPHandler(BaseHTTPRequestHandler):
    # Allow slow agent calls without the HTTP server itself cutting
    # the connection prematurely.
    timeout = 120

    def _send_json(self, status_code, payload):
        body = safe_json_dumps(payload).encode("utf-8")

        self.send_response(status_code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        self._send_json(
            200,
            {
                "status": "ok",
                "agent": AGENT_NAME,
                "message": "Audit Planning AgentCore runtime is running.",
            },
        )

    def do_POST(self):
        try:
            content_length = int(self.headers.get("Content-Length", "0"))
            raw_body = self.rfile.read(content_length).decode("utf-8")

            payload = safe_json_loads(raw_body, {})
            result = run_agent(payload)

            self._send_json(200, result)

        except Exception as exc:
            self._send_json(
                200,
                {
                    "answer": f"Audit Planning Agent failed: {str(exc)}",
                    "error": str(exc),
                    "traceback": traceback.format_exc(),
                    "selectedAgent": AGENT_NAME,
                    "citations": [],
                    "sources": [],
                },
            )


def main():
    server = HTTPServer(("0.0.0.0", PORT), AgentCoreHTTPHandler)
    server.timeout = 120
    print(f"Audit Planning AgentCore runtime running on port {PORT}", flush=True)
    server.serve_forever()


if __name__ == "__main__":
    main()